<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !=='undefined' ? title : 'attend.io' %></title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header>
        <div class="container">
            <nav>
                <div class="nav-logo">
                    <img src="/images/logo.png" alt="attend.io logo">
                    <span>attend.io</span>
                </div>
                <div class="nav-links">
                    <a href="/"><i class="fa-solid fa-house"></i> Home</a>

                    <% if (typeof user !== 'undefined' && user._id) { %>
                        <!-- Links for Logged In Users -->
                        <a href="/profile"><i class="fa-solid fa-id-card"></i> Profile</a>
                        
                        <% if (user.role === 'teacher') { %>
                            <a href="/manage-subjects"><i class="fa-solid fa-book"></i> Subjects</a>
                            <a href="/mark-attendance"><i class="fa-solid fa-clipboard-check"></i> Mark Attendance</a>
                        <% } else { %>
                            <a href="/view-attendance"><i class="fa-solid fa-chart-line"></i> My Attendance</a>
                        <% } %>

                        <span class="nav-welcome">
                            <i class="fa-solid fa-circle-user"></i> Welcome <strong><%= user.firstName %></strong>
                        </span>
                        <a href="/logout" class="logout-btn"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>

                    <% } else { %>
                        <!-- Links for Guests -->
                        <a href="/about"><i class="fa-solid fa-info-circle"></i> About</a>
                        <a href="/signup"><i class="fa-solid fa-user-plus"></i> Sign Up</a>
                        <a href="/login"><i class="fa-solid fa-right-to-bracket"></i> Login</a>
                    <% } %>
                </div>
            </nav>
        </div>
    </header>

    <main>