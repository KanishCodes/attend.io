<%- include("partials/header", { title: "Sign In" }) %>

  <div class="card max-w-500 mt-2">
    <h1><i class="fa-solid fa-lock accent-text"></i> Login</h1>
    <p>Welcome back! Please enter your credentials.</p>

    <form action="/login" method="POST" class="mt-1">
      <div class="form-group">
        <label for="email">Email Address<span class="required-star">*</span></label>
        <input type="email" id="email" name="email" placeholder="Enter your email" required>
      </div>
      <div class="form-group">
        <label for="password">Password<span class="required-star">*</span></label>
        <input type="password" id="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit">Sign In <i class="fa-solid fa-arrow-right"></i></button>

      <div style="text-align: center; margin: 1.5rem 0; position: relative;">
        <hr style="border: 0; border-top: 1px solid #ddd;">
        <span style="position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: #fff; padding: 0 10px; color: #888; font-size: 0.9rem;">OR</span>
      </div>

      <a href="/auth/google" style="display: flex; align-items: center; justify-content: center; text-decoration: none; background: #fff; color: #444; border: 1px solid #ddd; padding: 0.8rem; border-radius: 8px; font-weight: 500; transition: background 0.3s;">
        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" style="width: 18px; margin-right: 10px;">
        Continue with Google
      </a>
    </form>

    <p style="text-align: center; margin-top: 1.5rem;">
      Don't have an account? <a href="/signup" class="accent-text">Sign up here</a>
    </p>
  </div>

  <%- include("partials/footer") %>